{
  "name": "getqibla",
  "version": "0.1.0",
  "private": true,
  "description": "A simple, private, mobile-first Qibla direction finder.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "cf:dev": "npm run build && wrangler dev",
    "build": "astro build",
    "deploy": "npm run build && npm run deploy:worker",
    "deploy:dry-run": "npm run build && npm run deploy:worker -- --dry-run",
    "deploy:worker": "wrangler deploy",
    "preview": "astro preview",
    "check": "astro check",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "astro": "^7.1.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
