---
import { localeCodes, localePaths, translations, type LocaleCopy, type SupportedLocale } from '../i18n';

interface Props {
  copy: LocaleCopy;
  locale: SupportedLocale;
}

const { copy, locale } = Astro.props;

const tickMarks = Array.from({ length: 36 });
---

<section class="finder" aria-labelledby="page-title">
  <div class="finder__intro">
    <h1 id="page-title">{copy.heading}</h1>
    <label class="language-picker">
      <span>{copy.languageLabel}</span>
      <select data-language aria-label={copy.languageLabel}>
        {localeCodes.map((code) => <option value={localePaths[code]} selected={code === locale}>{translations[code].name}</option>)}
      </select>
    </label>
  </div>

  <div
    class="compass-panel"
    data-compass-panel
    data-state="idle"
    data-starting={copy.starting}
    data-start={copy.start}
    data-requesting-location={copy.requestingLocation}
    data-requesting-compass={copy.requestingCompass}
    data-calibration-status={copy.calibrationStatus}
    data-compass-unavailable={copy.compassUnavailable}
    data-compass-no-reading={copy.compassNoReading}
    data-compass-fallback-copy={copy.compassFallbackText}
    data-compass-fallback-status={copy.compassFallbackStatus}
    data-location-unavailable={copy.locationUnavailable}
    data-browser-location-unavailable={copy.browserLocationUnavailable}
    data-browser-location-help={copy.browserLocationHelp}
    data-secure-connection={copy.secureConnection}
    data-secure-connection-help={copy.secureConnectionHelp}
    data-location-denied={copy.locationDenied}
    data-location-denied-help={copy.locationDeniedHelp}
    data-location-not-found={copy.locationNotFound}
    data-location-not-found-help={copy.locationNotFoundHelp}
    data-location-timeout={copy.locationTimeout}
    data-location-timeout-help={copy.locationTimeoutHelp}
    data-generic-help={copy.genericHelp}
    data-location-status-unavailable={copy.locationStatusUnavailable}
    data-cardinals={JSON.stringify(copy.cardinals)}
    data-angle-summary={copy.angleSummary}
  >
    <div
      class="compass-status"
      data-status
      data-move-message={copy.movePhone}
      data-aligned-message={copy.aligned}
      aria-live="polite"
    >
      <span class="status-dot" aria-hidden="true"></span>
      <span data-status-text>{copy.privacy}</span>
    </div>

    <div class="compass" data-compass aria-label={copy.compassLabel} role="img">
      <div class="compass__dial" data-dial>
        {
          tickMarks.map((_, index) => (
            <span
              class:list={[
                'compass__tick',
                {
                  'compass__tick--medium': index % 3 === 0,
                  'compass__tick--major': index % 9 === 0,
                },
              ]}
              style={`--tick-angle: ${index * 10}deg`}
              aria-hidden="true"
            ></span>
          ))
        }
        <span class="compass__direction compass__direction--north">N</span>
        <span class="compass__direction compass__direction--east">E</span>
        <span class="compass__direction compass__direction--south">S</span>
        <span class="compass__direction compass__direction--west">W</span>
      </div>
      <div class="compass__arrow" data-qibla-arrow aria-hidden="true">
        <span class="compass__arrow-head"></span>
        <span class="compass__arrow-stem"></span>
      </div>
      <div class="compass__center" aria-hidden="true">
        <span class="kaaba-mark"></span>
      </div>
    </div>

    <div class="bearing" data-bearing-block hidden>
      <div class="bearing__item">
        <span class="bearing__label">{copy.directionLabel}</span>
        <strong data-cardinal>—</strong>
      </div>
      <div class="bearing__item">
        <span class="bearing__label">
          <span>{copy.angleLabel}</span>
          <button
            class="info-button"
            type="button"
            data-bearing-info
            aria-label={copy.explainAngle}
            aria-controls="bearing-help"
            aria-expanded="false"
          >
            i
          </button>
        </span>
        <strong><span data-bearing>—</span><span class="bearing__unit">°</span></strong>
      </div>
      <p
        class="bearing-help"
        id="bearing-help"
        data-bearing-help
        data-scale-message={copy.bearingHelp}
        hidden
      >{copy.bearingHelp}</p>
    </div>

    <button class="primary-button" type="button" data-start>
      <span data-start-text>{copy.start}</span>
      <span class="button-spinner" aria-hidden="true"></span>
    </button>

    <p class="permission-note">{copy.locationAccess}</p>
    <p class="method-copy">{copy.calculation}</p>

    <button class="text-button" type="button" data-calibrate hidden>{copy.recalibrate}</button>

    <div class="calibration" data-calibration hidden>
      <p>{copy.calibrationHint}</p>
    </div>

    <div class="error-state" data-error hidden>
      <p class="error-state__title" data-error-title>{copy.compassUnavailable}</p>
      <p data-error-copy>{copy.compassFallbackText}</p>
      <button class="secondary-button" type="button" data-retry>{copy.retry}</button>
    </div>
  </div>

</section>

<script>
  import {
    calculateQibla,
    calculateCompassHeading,
    getRelativeQiblaBearing,
    normalizeDegrees,
    type Coordinates,
  } from '../lib/qibla';

  type CompassState = 'idle' | 'starting' | 'ready' | 'fallback' | 'error';

  const root = document.querySelector<HTMLElement>('[data-compass-panel]');
  const startButton = document.querySelector<HTMLButtonElement>('[data-start]');
  const startText = document.querySelector<HTMLElement>('[data-start-text]');
  const status = document.querySelector<HTMLElement>('[data-status]');
  const statusText = document.querySelector<HTMLElement>('[data-status-text]');
  const dial = document.querySelector<HTMLElement>('[data-dial]');
  const bearingBlock = document.querySelector<HTMLElement>('[data-bearing-block]');
  const bearingValue = document.querySelector<HTMLElement>('[data-bearing]');
  const cardinalValue = document.querySelector<HTMLElement>('[data-cardinal]');
  const bearingInfoButton = document.querySelector<HTMLButtonElement>('[data-bearing-info]');
  const bearingHelp = document.querySelector<HTMLElement>('[data-bearing-help]');
  const qiblaArrow = document.querySelector<HTMLElement>('[data-qibla-arrow]');
  const calibrateButton = document.querySelector<HTMLButtonElement>('[data-calibrate]');
  const calibration = document.querySelector<HTMLElement>('[data-calibration]');
  const errorState = document.querySelector<HTMLElement>('[data-error]');
  const errorTitle = document.querySelector<HTMLElement>('[data-error-title]');
  const errorCopy = document.querySelector<HTMLElement>('[data-error-copy]');
  const retryButton = document.querySelector<HTMLButtonElement>('[data-retry]');

  let currentState: CompassState = 'idle';
  let qiblaBearing = 0;
  let location: Coordinates | null = null;
  let orientationListening = false;
  let headingReceived = false;
  let headingTimeout: number | null = null;
  const alignmentTolerance = 8;

  function message(key: keyof DOMStringMap, fallback: string): string {
    return root?.dataset[key] ?? fallback;
  }

  function setState(state: CompassState): void {
    currentState = state;
    root?.setAttribute('data-state', state);
  }

  function setStatus(message: string): void {
    if (statusText) statusText.textContent = message;
  }

  function setAlignment(aligned: boolean): void {
    root?.setAttribute('data-aligned', String(aligned));
  }

  function setBearing(bearing: number): void {
    const rounded = Math.round(normalizeDegrees(bearing));
    const direction = getCardinalDirection(bearing);
    if (bearingValue) bearingValue.textContent = String(rounded);
    if (cardinalValue) cardinalValue.textContent = direction;
    if (bearingHelp) {
      const scaleMessage = bearingHelp.dataset.scaleMessage ?? '';
      const summary = message('angleSummary', '{degrees}° is the angle from north. The Qibla is toward {direction}.')
        .replace('{degrees}', String(rounded))
        .replace('{direction}', direction.toLocaleLowerCase());
      bearingHelp.textContent = `${summary} ${scaleMessage}`;
    }
  }

  function getCardinalDirection(bearing: number): string {
    let directions = ['North', 'North-east', 'East', 'South-east', 'South', 'South-west', 'West', 'North-west'];
    try {
      const parsed = JSON.parse(root?.dataset.cardinals ?? '[]');
      if (Array.isArray(parsed) && parsed.length === 8) directions = parsed;
    } catch {
      // Keep the English fallback if translated data is unavailable.
    }
    const index = Math.round(normalizeDegrees(bearing) / 45) % directions.length;
    return directions[index];
  }

  function getOrientationAngle(): number {
    const screenAngle = window.screen.orientation?.angle;
    if (typeof screenAngle === 'number') return screenAngle;

    const legacyAngle = (window as Window & { orientation?: number }).orientation;
    return typeof legacyAngle === 'number' ? legacyAngle : 0;
  }

  function readHeading(event: DeviceOrientationEvent): number | null {
    const compassEvent = event as DeviceOrientationEvent & { webkitCompassHeading?: number };
    const webkitHeading = compassEvent.webkitCompassHeading;

    if (typeof webkitHeading === 'number' && Number.isFinite(webkitHeading)) {
      return normalizeDegrees(webkitHeading);
    }

    if (event.absolute !== true) return null;
    if (typeof event.alpha !== 'number' || !Number.isFinite(event.alpha)) return null;

    if (typeof event.beta !== 'number' || !Number.isFinite(event.beta)) return null;
    if (typeof event.gamma !== 'number' || !Number.isFinite(event.gamma)) return null;

    const tiltCompensatedHeading = calculateCompassHeading(event.alpha, event.beta, event.gamma);

    return tiltCompensatedHeading === null
      ? null
      : normalizeDegrees(tiltCompensatedHeading + getOrientationAngle());
  }

  function handleOrientation(event: DeviceOrientationEvent): void {
    if (currentState !== 'ready') return;

    const heading = readHeading(event);
    if (heading === null) return;

    headingReceived = true;
    if (headingTimeout !== null) window.clearTimeout(headingTimeout);
    const rotation = getRelativeQiblaBearing(qiblaBearing, heading);
    const aligned = Math.abs(rotation) <= alignmentTolerance;
    dial?.style.setProperty('--dial-rotation', `${-heading}deg`);
    dial?.style.setProperty('--dial-counter-rotation', `${heading}deg`);
    qiblaArrow?.style.setProperty('--arrow-rotation', `${rotation}deg`);
    setAlignment(aligned);
    setStatus(
      aligned
        ? status?.dataset.alignedMessage ?? 'You are facing the Qibla.'
        : status?.dataset.moveMessage ?? 'Keep moving your phone until the arrow turns green.',
    );
  }

  function stopOrientation(): void {
    if (orientationListening) {
      window.removeEventListener('deviceorientation', handleOrientation, true);
      window.removeEventListener('deviceorientationabsolute', handleOrientation, true);
    }
    if (headingTimeout !== null) window.clearTimeout(headingTimeout);
    headingTimeout = null;
    orientationListening = false;
  }

  function startOrientation(): boolean {
    if (typeof window.DeviceOrientationEvent === 'undefined') return false;

    window.addEventListener('deviceorientation', handleOrientation, true);
    window.addEventListener('deviceorientationabsolute', handleOrientation, true);
    orientationListening = true;
    return true;
  }

  function waitForHeading(): void {
    headingReceived = false;
    headingTimeout = window.setTimeout(() => {
      if (currentState === 'ready' && !headingReceived) {
        showFallback(message('compassNoReading', 'Your phone did not provide a compass reading.'));
      }
    }, 6000);
  }

  async function requestOrientationPermission(): Promise<boolean> {
    const orientation = window.DeviceOrientationEvent as (typeof DeviceOrientationEvent & {
      requestPermission?: (absolute?: boolean) => Promise<'granted' | 'denied'>;
    }) | undefined;

    if (!orientation) return false;

    if (typeof orientation.requestPermission !== 'function') return startOrientation();

    try {
      const permission = await orientation.requestPermission(true);
      return permission === 'granted' && startOrientation();
    } catch {
      return false;
    }
  }

  function requestLocation(): Promise<GeolocationPosition> {
    return new Promise((resolve, reject) => {
      if (!navigator.geolocation) {
        reject(new Error('geolocation-unavailable'));
        return;
      }

      const localHostnames = new Set(['localhost', '127.0.0.1', '[::1]']);
      if (!window.isSecureContext && !localHostnames.has(window.location.hostname)) {
        reject(new Error('secure-context-required'));
        return;
      }

      navigator.geolocation.getCurrentPosition(resolve, reject, {
        enableHighAccuracy: false,
        timeout: 15000,
        maximumAge: 300000,
      });
    });
  }

  function showFallback(fallbackMessage = message('compassUnavailable', 'Your phone compass is not available here.')): void {
    stopOrientation();
    setState('fallback');
    setAlignment(false);
    if (errorTitle) errorTitle.textContent = fallbackMessage;
    if (errorCopy) errorCopy.textContent = message('compassFallbackCopy', 'Use the angle above with a separate compass.');
    if (errorState) errorState.hidden = false;
    if (calibrateButton) calibrateButton.hidden = true;
    if (bearingBlock) bearingBlock.hidden = false;
    setStatus(message('compassFallbackStatus', 'Compass unavailable. Use the angle above.'));
  }

  function showError(errorMessage: string, copy = message('genericHelp', 'Check your browser permissions, then try again.')): void {
    stopOrientation();
    setState('error');
    setAlignment(false);
    if (errorTitle) errorTitle.textContent = errorMessage;
    if (errorCopy) errorCopy.textContent = copy;
    if (errorState) errorState.hidden = false;
    if (calibrateButton) calibrateButton.hidden = true;
    setStatus(message('locationStatusUnavailable', 'Location unavailable.'));
  }

  async function begin(): Promise<void> {
    if (!startButton || currentState === 'starting') return;

    setState('starting');
    startButton.disabled = true;
    if (startText) startText.textContent = message('starting', 'Finding Qibla…');
    if (errorState) errorState.hidden = true;
    if (calibration) calibration.hidden = true;
    setAlignment(false);
    setStatus(message('requestingCompass', 'Allow compass access to point the arrow.'));

    const hasCompass = await requestOrientationPermission();

    try {
      setStatus(message('requestingLocation', 'Allow location to find your direction.'));
      const position = await requestLocation();
      location = {
        latitude: position.coords.latitude,
        longitude: position.coords.longitude,
      };
      const result = calculateQibla(location);
      qiblaBearing = result.bearing;
      setBearing(qiblaBearing);

      if (bearingBlock) bearingBlock.hidden = false;

      if (hasCompass) {
        setState('ready');
        if (calibrateButton) calibrateButton.hidden = false;
        setStatus(status?.dataset.moveMessage ?? 'Keep moving your phone until the arrow turns green.');
        waitForHeading();
      } else {
        showFallback();
      }
    } catch (error) {
      const code =
        typeof error === 'object' && error !== null && 'code' in error
          ? Number(error.code)
          : 0;
      const errorMessage = error instanceof Error ? error.message : '';

      if (errorMessage === 'geolocation-unavailable') {
        showError(message('browserLocationUnavailable', 'This browser cannot provide your location.'), message('browserLocationHelp', 'Try a browser with location access enabled.'));
      } else if (errorMessage === 'secure-context-required') {
        showError(message('secureConnection', 'Location needs a secure connection.'), message('secureConnectionHelp', 'Open this site over HTTPS, then try again.'));
      } else if (code === 1) {
        showError(message('locationDenied', 'Location access is needed to calculate Qibla.'), message('locationDeniedHelp', 'Allow location for this site, then try again.'));
      } else if (code === 2) {
        showError(message('locationNotFound', 'Your browser could not find your location.'), message('locationNotFoundHelp', 'Turn on Location Services, then try again.'));
      } else if (code === 3) {
        showError(message('locationTimeout', 'Location took too long.'), message('locationTimeoutHelp', 'Move somewhere with a clearer signal, then try again.'));
      } else {
        showError(message('locationUnavailable', 'We could not get your location.'));
      }
    } finally {
      startButton.disabled = false;
      if (startText) startText.textContent = message('start', 'Find Qibla');
    }
  }

  function calibrate(): void {
    if (calibration) calibration.hidden = !calibration.hidden;
    setStatus(message('calibrationStatus', 'Move your phone slowly in a figure eight.'));
  }

  startButton?.addEventListener('click', begin);
  retryButton?.addEventListener('click', begin);
  calibrateButton?.addEventListener('click', calibrate);

  bearingInfoButton?.addEventListener('click', () => {
    const expanded = bearingInfoButton.getAttribute('aria-expanded') === 'true';
    bearingInfoButton.setAttribute('aria-expanded', String(!expanded));
    if (bearingHelp) bearingHelp.hidden = expanded;
  });

  const languageSelect = document.querySelector<HTMLSelectElement>('[data-language]');
  languageSelect?.addEventListener('change', () => {
    window.location.assign(languageSelect.value);
  });
</script>
