---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteFooter from './SiteFooter.astro';
import { articles, updatedDate, type Article } from '../content/articles';
import { SITE_URL } from '../config';

interface Props { article: Article }
const { article } = Astro.props;
const path = `/${article.slug}/`;
const siteUrl = SITE_URL;
const canonicalUrl = new URL(path, siteUrl).toString();
const related = articles.filter((item) => item.slug !== article.slug && item.slug !== 'privacy').slice(0, 4);
const graph: object[] = [
  {
    '@context':'https://schema.org','@type':'Article','@id':`${canonicalUrl}#article`,headline:article.heading,
    description:article.description,datePublished:updatedDate,dateModified:updatedDate,inLanguage:'en',mainEntityOfPage:canonicalUrl,
    author:{'@type':'Person',name:'Hadi Khan',url:'https://www.linkedin.com/in/okhadi/'},
    publisher:{'@type':'Person',name:'Hadi Khan'},
  },
  {
    '@context':'https://schema.org','@type':'BreadcrumbList',itemListElement:[
      {'@type':'ListItem',position:1,name:'GetQibla',item:new URL('/',siteUrl).toString()},
      {'@type':'ListItem',position:2,name:article.heading,item:canonicalUrl},
    ],
  },
];
if (article.faqs?.length) graph.push({'@context':'https://schema.org','@type':'FAQPage',mainEntity:article.faqs.map((faq)=>({'@type':'Question',name:faq.question,acceptedAnswer:{'@type':'Answer',text:faq.answer}}))});
---
<BaseLayout title={article.title} description={article.description} path={path} structuredData={graph} article>
  <main>
    <article class="article-shell">
      <a class="back-link" href="/">GetQibla</a>
      <header class="article-header">
        <h1>{article.heading}</h1>
        <p class="article-summary">{article.summary}</p>
        <p class="article-meta">Updated <time datetime={updatedDate}>{updatedDate}</time> · Hadi Khan</p>
      </header>
      {article.sections.map((section) => (
        <section class="article-section">
          <h2>{section.heading}</h2>
          {section.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
          {section.bullets && <ul>{section.bullets.map((item) => <li>{item}</li>)}</ul>}
        </section>
      ))}
      {article.faqs?.length && <section class="article-section"><h2>Questions and answers</h2><div class="faq-list">{article.faqs.map((faq) => <details><summary>{faq.question}</summary><p>{faq.answer}</p></details>)}</div></section>}
      {article.sources?.length && <section class="article-section sources"><h2>Sources and verification</h2><ul>{article.sources.map((source) => <li><a href={source.href}>{source.label}</a></li>)}</ul></section>}
      <nav class="article-related" aria-label="Related Qibla guides">
        <h2>Related guides</h2>
        {related.map((item) => <a href={`/${item.slug}/`}>{item.heading}</a>)}
      </nav>
      <a class="article-cta" href="/">Open the Qibla compass</a>
    </article>
    <SiteFooter />
  </main>
</BaseLayout>
