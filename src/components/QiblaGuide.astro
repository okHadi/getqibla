---
import type { LocaleCopy, SupportedLocale } from '../i18n';

interface Props {
  copy: LocaleCopy;
  locale: SupportedLocale;
}

const { copy, locale } = Astro.props;
const resources = locale === 'en' ? [
  ['/how-to-find-qibla-direction/', 'How to find Qibla direction'],
  ['/qibla-angle/', 'Understand the Qibla angle'],
  ['/qibla-compass-not-working/', 'Fix a phone compass'],
  ['/how-qibla-is-calculated/', 'Read the calculation method'],
] : [];
---

<section class="knowledge" id="qibla-guide" aria-labelledby="qibla-guide-title">
  <div class="knowledge__intro">
    <h2 id="qibla-guide-title">{copy.guide.title}</h2>
    <p>{copy.guide.introduction}</p>
  </div>

  <div class="knowledge__section">
    <h2>{copy.guide.stepsTitle}</h2>
    <ol class="knowledge__steps">
      {copy.guide.steps.map((step) => <li><div><h3>{step.title}</h3><p>{step.text}</p></div></li>)}
    </ol>
  </div>

  <div class="knowledge__section">
    <h2>{copy.guide.calculationTitle}</h2>
    <p>{copy.guide.calculation}</p>
  </div>

  <div class="knowledge__section">
    <h2>{copy.guide.factsTitle}</h2>
    <ul class="knowledge__facts">{copy.guide.facts.map((fact) => <li>{fact}</li>)}</ul>
  </div>

  <div class="knowledge__section knowledge__faq" id="qibla-faq">
    <h2>{copy.guide.faqTitle}</h2>
    <div class="faq-list">
      {copy.guide.faqs.map((faq) => <details><summary>{faq.question}</summary><p>{faq.answer}</p></details>)}
    </div>
  </div>

  {resources.length > 0 && (
    <nav class="resource-links" aria-label="Qibla guides">
      {resources.map(([href, label]) => <a href={href}>{label}</a>)}
    </nav>
  )}
</section>
