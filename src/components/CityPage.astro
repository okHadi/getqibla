---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteFooter from './SiteFooter.astro';
import { calculateQibla } from '../lib/qibla';
import { qiblaCities, type QiblaCity } from '../content/cities';
import { SITE_URL } from '../config';

interface Props { city: QiblaCity }
const { city } = Astro.props;
const result = calculateQibla({latitude:city.latitude,longitude:city.longitude});
const angle = Math.round(result.bearing * 10) / 10;
const distance = Math.round(result.distanceKm);
const cardinals = ['north','north-east','east','south-east','south','south-west','west','north-west'];
const cardinal = cardinals[Math.round(result.bearing / 45) % 8];
const path = `/qibla-direction/${city.slug}/`;
const title = `Qibla Direction in ${city.city} – ${angle}° ${cardinal} | GetQibla`;
const description = `The Qibla direction in ${city.city}, ${city.country} is ${angle}° from true north, toward ${cardinal}. See the angle and open the live Qibla compass.`;
const siteUrl = SITE_URL;
const canonicalUrl = new URL(path,siteUrl).toString();
const schema = [
  {'@context':'https://schema.org','@type':'WebPage','@id':canonicalUrl,url:canonicalUrl,name:title,description,dateModified:'2026-07-18',about:{'@type':'Thing',name:'Qibla direction'}},
  {'@context':'https://schema.org','@type':'BreadcrumbList',itemListElement:[{'@type':'ListItem',position:1,name:'GetQibla',item:new URL('/',siteUrl).toString()},{'@type':'ListItem',position:2,name:`Qibla direction in ${city.city}`,item:canonicalUrl}]},
];
const related = qiblaCities.filter((item)=>item.slug!==city.slug).slice(0,4);
---
<BaseLayout title={title} description={description} path={path} structuredData={schema} article>
  <main>
    <article class="article-shell city-page">
      <a class="back-link" href="/">GetQibla</a>
      <header class="article-header">
        <h1>Qibla direction in {city.city}</h1>
        <p class="article-summary">In {city.city}, {city.country}, the Qibla bearing is <strong>{angle}° from true north</strong>, toward {cardinal}. The Kaaba is approximately {distance.toLocaleString('en')} km away.</p>
        <p class="article-meta">Verified with GetQibla calculation · Updated <time datetime="2026-07-18">2026-07-18</time></p>
      </header>
      <dl class="city-bearing">
        <div><dt>Direction</dt><dd>{cardinal}</dd></div>
        <div><dt>Angle</dt><dd>{angle}°</dd></div>
        <div><dt>Distance</dt><dd>{distance.toLocaleString('en')} km</dd></div>
      </dl>
      <section class="article-section"><h2>How to face the Qibla in {city.city}</h2><p>Find true north, then turn clockwise to {angle}°. For a live reading, open the compass below and allow location and motion access. Keep the phone away from magnets and large metal objects.</p><p>{city.note}</p></section>
      <section class="article-section"><h2>How this angle was calculated</h2><p>GetQibla uses the coordinates {city.latitude}, {city.longitude} and the Kaaba’s fixed coordinates to calculate the initial great-circle bearing. The result is measured from true north. A magnetic compass may need local declination correction.</p><p><a href="/how-qibla-is-calculated/">Read the complete calculation method.</a></p></section>
      <nav class="article-related" aria-label="Other city Qibla directions"><h2>Other cities</h2>{related.map((item)=><a href={`/qibla-direction/${item.slug}/`}>Qibla direction in {item.city}</a>)}</nav>
      <a class="article-cta" href="/">Use my exact location</a>
    </article>
    <SiteFooter />
  </main>
</BaseLayout>
