---
import HomePage from '../../components/HomePage.astro';
import { getLocaleCopy, localeCodes, type SupportedLocale } from '../../i18n';

export function getStaticPaths() {
  return localeCodes.filter((code) => code !== 'en').map((lang) => ({ params: { lang }, props: { lang } }));
}

interface Props { lang: SupportedLocale }
const { lang } = Astro.props;
---
<HomePage copy={getLocaleCopy(lang)} locale={lang} />
