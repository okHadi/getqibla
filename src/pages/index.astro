---
import QiblaFinder from '../components/QiblaFinder.astro';
import QiblaGuide from '../components/QiblaGuide.astro';
import { qiblaGuide } from '../content/qiblaGuide';
import '../styles/global.css';

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://getqibla.app';
const canonicalUrl = new URL('/', siteUrl).toString();
const description =
  'Find the Qibla direction online with your location and phone compass. Get a simple, private Qibla angle to the Kaaba in Makkah, with clear steps for prayer.';
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${canonicalUrl}#app`,
      name: 'GetQibla',
      url: canonicalUrl,
      description,
      applicationCategory: 'UtilitiesApplication',
      operatingSystem: 'Any',
      browserRequirements: 'Requires a modern browser with location access; compass access is needed for the live arrow.',
      isAccessibleForFree: true,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      creator: {
        '@type': 'Person',
        name: 'Hadi Khan',
        url: 'https://www.linkedin.com/in/okhadi/',
        sameAs: ['https://www.linkedin.com/in/okhadi/', 'https://github.com/okHadi'],
      },
      license: 'https://opensource.org/license/mit/',
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#qibla-faq`,
      url: `${canonicalUrl}#qibla-faq`,
      mainEntity: qiblaGuide.faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.answer,
        },
      })),
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0c0c0b" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='16' fill='%230c0c0b'/%3E%3Cpath d='M32 9l9 23-9 23-9-23L32 9z' fill='%23d2b475'/%3E%3Ccircle cx='32' cy='32' r='5' fill='%230c0c0b'/%3E%3C/svg%3E" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Qibla Direction Finder — Find the Qibla Online" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="GetQibla" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Qibla Direction Finder — Find the Qibla Online" />
    <meta name="twitter:description" content={description} />
    <title>Qibla Direction Finder — Find the Qibla Online</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <main>
      <QiblaFinder />
      <QiblaGuide />
      <footer class="attribution">
        <p>Sadaqah Jariyah for Hadi Khan</p>
        <nav class="social-links" aria-label="Social links">
          <a href="https://www.linkedin.com/in/okhadi/" target="_blank" rel="noreferrer" aria-label="Hadi Khan on LinkedIn" title="LinkedIn">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M6.5 8.25A1.75 1.75 0 1 0 6.5 4.75a1.75 1.75 0 0 0 0 3.5ZM5 9.75h3v9.5H5v-9.5Zm4.75 0h2.88v1.3h.04c.4-.75 1.38-1.55 2.84-1.55 3.04 0 3.6 2 3.6 4.6v5.15h-3v-4.57c0-1.09-.02-2.5-1.52-2.5s-1.75 1.19-1.75 2.42v4.65h-3v-9.5Z"></path>
            </svg>
          </a>
          <a href="https://github.com/okHadi" target="_blank" rel="noreferrer" aria-label="Hadi Khan on GitHub" title="GitHub">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M12 2.5a9.5 9.5 0 0 0-3 18.51c.47.09.65-.2.65-.46v-1.62c-2.65.58-3.21-1.12-3.21-1.12-.43-1.1-1.06-1.39-1.06-1.39-.86-.59.07-.58.07-.58.95.07 1.45.98 1.45.98.85 1.45 2.23 1.03 2.78.79.08-.62.33-1.03.6-1.27-2.12-.24-4.35-1.06-4.35-4.72 0-1.04.37-1.89.98-2.55-.1-.24-.43-1.2.09-2.51 0 0 .8-.26 2.62.97A9.1 9.1 0 0 1 12 7.2a9.1 9.1 0 0 1 2.39.32c1.82-1.23 2.62-.97 2.62-.97.52 1.31.19 2.27.09 2.51.61.66.98 1.51.98 2.55 0 3.67-2.24 4.48-4.37 4.72.34.29.64.84.64 1.7v2.52c0 .26.18.56.66.46A9.5 9.5 0 0 0 12 2.5Z"></path>
            </svg>
          </a>
        </nav>
      </footer>
    </main>
  </body>
</html>
