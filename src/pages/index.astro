---
import QiblaFinder from '../components/QiblaFinder.astro';
import '../styles/global.css';

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://getqibla.app';
const canonicalUrl = new URL('/', siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#101311" />
    <meta name="description" content="Find the Qibla direction from your location with a simple, private online compass." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='16' fill='%23101311'/%3E%3Cpath d='M32 10l8.2 21.8L32 54l-8.2-22.2L32 10z' fill='%2369d3a0'/%3E%3Ccircle cx='32' cy='32' r='5' fill='%23101311'/%3E%3C/svg%3E" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Qibla Direction Finder — Find the Qibla Online" />
    <meta property="og:description" content="A simple, private online compass for finding the Qibla direction." />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="GetQibla" />
    <title>Qibla Direction Finder — Find the Qibla Online</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebApplication',
      name: 'GetQibla',
      url: canonicalUrl,
      description: 'A simple, private online compass for finding the Qibla direction.',
      applicationCategory: 'UtilitiesApplication',
      operatingSystem: 'Any',
      isAccessibleForFree: true,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      license: 'https://opensource.org/license/mit/',
    })} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="GetQibla home">
        <span class="brand-mark" aria-hidden="true"><span></span></span>
        <span>GetQibla</span>
      </a>
      <label class="language-picker">
        <span class="sr-only">Language</span>
        <select data-language aria-label="Language">
          <option value="en">English</option>
          <option value="ar" disabled>Arabic (soon)</option>
          <option value="ur" disabled>Urdu (soon)</option>
        </select>
      </label>
    </header>

    <main>
      <QiblaFinder />
    </main>

    <footer class="site-footer">
      <p>Free and open source.</p>
      <a href="https://opensource.org/license/mit/" rel="noreferrer">MIT license</a>
    </footer>
  </body>
</html>
